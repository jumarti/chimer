# Copy this file to .env and fill in real credentials.
# .env is gitignored — never commit it.
#
# Rotate the password if it was ever shared or visible in chat/logs.

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------
RTSP_URL=rtsp://user:password@camera-host:554/cam/realmonitor?channel=1&subtype=0

# ---------------------------------------------------------------------------
# OPTIONAL — override defaults shown here only if you need a different value
# ---------------------------------------------------------------------------

# HTTP server bind address and port
#HOST=0.0.0.0
#PORT=8080

# Seconds between camera polls (4 s × 5-frame window ≈ 20 s of context)
#POLL_INTERVAL_S=4.0

# Frame capture backend: opencv (default) or ffmpeg
#CAPTURE_METHOD=opencv

# ffmpeg subprocess timeout in seconds
#FFMPEG_TIMEOUT_S=12

# OpenCV VideoCapture timeouts in milliseconds (prevents hang on stale TCP)
#CAMERA_OPEN_TIMEOUT_MS=5000
#CAMERA_READ_TIMEOUT_MS=5000

# Debug bundle path and behaviour
#DEBUG_DIR=.data/debug
#DEBUG_ON_CHANGE=true
#DEBUG_RING_SIZE=3

# Capture every polled frame (disabled by default — can fill disk quickly)
#SAVE_CAPTURES=false
#CAPTURES_DIR=.data/captures
