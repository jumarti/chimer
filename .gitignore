# Arduino build artefacts
build/
*.elf
*.bin
*.hex
*.map

# Arduino IDE temp files
*.bak

# Python
__pycache__/
*.pyc
.venv/
# uv.lock is intentionally committed for reproducible installs

# Secrets
.env

# Local data (bulk captures + debug frames — NOT tests/fixtures/)
.data/
debug_everest/

# Host-side Docker bind mount targets — keep the directory skeleton,
# ignore actual frame files (can be large).
data/debug/*
!data/debug/.gitkeep
data/captures/*
!data/captures/.gitkeep

# OS
.DS_Store
Thumbs.db
